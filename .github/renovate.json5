{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "automerge": true,
  "automergeType": "branch",
  "git-submodules": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Ubuntu runner versions in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "runner:\\s+(?<depName>ubuntu)-(?<currentValue>\\d+\\.\\d+)(-arm)?"
      ],
      "datasourceTemplate": "github-runners"
    },
    {
      "customType": "regex",
      "description": "Update Ubuntu Docker images in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "BASE_IMAGE:\\s+mirror\\.gcr\\.io/library/(?<depName>ubuntu):(?<currentValue>\\d+\\.\\d+)",
        "RUNTIME_IMAGE:\\s+mirror\\.gcr\\.io/library/(?<depName>ubuntu):(?<currentValue>\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update NVIDIA CUDA Docker images in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?:mirror\\.gcr\\.io/)?(?<depName>nvidia/cuda):(?<currentValue>[\\d.]+-(?:devel|runtime)-ubuntu[\\d.]+)",
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["nvidia/cuda"],
      "matchCurrentValue": "/^[\\d.]+-devel-ubuntu[\\d.]+$/",
      "allowedVersions": "/^[\\d.]+-devel-ubuntu[\\d.]+$/"
    },
    {
      "matchPackageNames": ["nvidia/cuda"],
      "matchCurrentValue": "/^[\\d.]+-runtime-ubuntu[\\d.]+$/",
      "allowedVersions": "/^[\\d.]+-runtime-ubuntu[\\d.]+$/"
    }
  ]
}
