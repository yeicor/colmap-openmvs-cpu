{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "automerge": true,
  "automergeType": "branch",
  "git-submodules": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Ubuntu runner versions in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "runner:\\s+(?<depName>ubuntu)-(?<currentValue>\\d+\\.\\d+)(?:-arm)?"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "canonical/ubuntu",
      "versioningTemplate": "ubuntu"
    },
    {
      "customType": "regex",
      "description": "Update Ubuntu Docker images in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "BASE_IMAGE:\\s+mirror\\.gcr\\.io/library/(?<depName>ubuntu):(?<currentValue>\\d+\\.\\d+)",
        "RUNTIME_IMAGE:\\s+mirror\\.gcr\\.io/library/(?<depName>ubuntu):(?<currentValue>\\d+\\.\\d+)"
      ],
      "autoReplaceStringTemplate": "mirror.gcr.io/library/{{{depName}}}:{{{newValue}}}",
      "datasourceTemplate": "docker",
      "versioningTemplate": "ubuntu"
    },
    {
      "customType": "regex",
      "description": "Update NVIDIA CUDA Docker images in GitHub Actions workflows",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "BASE_IMAGE:\\s+mirror\\.gcr\\.io/nvidia/(?<depName>cuda):(?<currentValue>[\\d.]+-devel-ubuntu[\\d.]+)",
        "RUNTIME_IMAGE:\\s+mirror\\.gcr\\.io/nvidia/(?<depName>cuda):(?<currentValue>[\\d.]+-runtime-ubuntu[\\d.]+)"
      ],
      "autoReplaceStringTemplate": "mirror.gcr.io/nvidia/{{{depName}}}:{{{newValue}}}",
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update ONNXRUNTIME_VERSION in Dockerfile",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "ONNXRUNTIME_VERSION=\"(?<currentValue>[\\d.]+)\""
      ],
      "depNameTemplate": "microsoft/onnxruntime",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>[\\d.]+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Use ubuntu versioning for ubuntu runner dependencies",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["canonical/ubuntu"],
      "versioning": "ubuntu"
    },
    {
      "description": "Use ubuntu versioning for ubuntu docker images",
      "matchDatasources": ["docker"],
      "matchDepNames": ["ubuntu"],
      "versioning": "ubuntu"
    },
    {
      "description": "Use loose versioning for NVIDIA CUDA docker images",
      "matchDatasources": ["docker"],
      "matchDepNames": ["cuda"],
      "versioning": "loose"
    },
    {
      "description": "Use semver versioning for ONNX Runtime releases",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["microsoft/onnxruntime"],
      "versioning": "semver",
      "extractVersion": "^v?(?<version>[\\d.]+)$"
    }
  ]
}
